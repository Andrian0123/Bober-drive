# Конфигурация Ollama Agent Hub

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT=120
OLLAMA_MAX_CONCURRENT=3

# Платные API (опционально)
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Получить: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Получить: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Логирование
LOG_LEVEL=info
LOG_PATH=./logs

# Автообновление
AUTO_UPDATE_MODELS=true
UPDATE_CHECK_INTERVAL=86400

# Плагины
PLUGINS_PATH=./plugins
PLUGINS_ENABLED=true

# Web UI (если используется)
WEBUI_PORT=3000
WEBUI_AUTH=false
